{
  "scenario_id": "pause_menu_focus",
  "version": 3,
  "description": "Press Escape and verify semantic node facts exposed by the pause-menu harness using the generic assert_value primitive.",
  "harness_scene": "res://test/harnesses/pause_menu_harness.tscn",
  "done_contract": {
    "input_action": "pause",
    "input_key": "Escape",
    "frame_budget": 2,
    "expected_focus_suffix": "ResumeButton"
  },
  "artifact_contract": {
    "required_files": [
      "summary.json",
      "event_log.json",
      "scene_tree.json",
      "console.log",
      "screenshots/before.png",
      "screenshots/after.png"
    ],
    "missing_file_is_failure": true
  },
  "exit_codes": {
    "pass": 0,
    "assertion_failure": 1,
    "runtime_error": 2,
    "timeout": 3,
    "artifact_generation_error": 4
  },
  "cli_contract": {
    "command_template": "godot --path <project> -- --test-mode --scenario <path> --artifacts <dir>"
  },
  "steps": [
    {
      "op": "load_harness",
      "scene": "res://test/harnesses/pause_menu_harness.tscn"
    },
    {
      "op": "checkpoint",
      "name": "before"
    },
    {
      "op": "press_action",
      "action": "pause"
    },
    {
      "op": "wait_frames",
      "frames": 2
    },
    {
      "op": "release_action",
      "action": "pause"
    },
    {
      "op": "checkpoint",
      "name": "after"
    },
    {
      "op": "assert_value",
      "checkpoint": "after",
      "path": "harness_state.nodes.pause_menu.visible",
      "comparator": "eq",
      "expected": true
    },
    {
      "op": "assert_value",
      "checkpoint": "after",
      "path": "harness_state.nodes.resume_button.focused",
      "comparator": "eq",
      "expected": true
    },
    {
      "op": "assert_value",
      "checkpoint": "after",
      "path": "harness_state.nodes.resume_button.enabled",
      "comparator": "eq",
      "expected": true
    },
    {
      "op": "assert_value",
      "checkpoint": "after",
      "path": "harness_state.nodes.resume_button.text",
      "comparator": "eq",
      "expected": "Resume"
    },
    {
      "op": "assert_value",
      "checkpoint": "after",
      "path": "harness_state.signals.pause_menu.menu_opened.count",
      "comparator": "gte",
      "expected": 1
    },
    {
      "op": "assert_value",
      "checkpoint": "after",
      "path": "harness_state.signals.resume_button.focus_entered.count",
      "comparator": "gte",
      "expected": 1
    },
    {
      "op": "quit"
    }
  ]
}
