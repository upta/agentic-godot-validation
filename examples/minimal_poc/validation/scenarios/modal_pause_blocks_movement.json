{
  "scenario_id": "modal_pause_blocks_movement",
  "version": 4,
  "description": "Compose the player actor and pause menu together, prove movement is blocked while the modal is active, then prove movement resumes after closing it.",
  "harness_scene": "res://examples/minimal_poc/validation/harnesses/modal_pause_movement_harness.tscn",
  "done_contract": {
    "pause_action": "pause",
    "pause_key": "Escape",
    "accept_action": "ui_accept",
    "accept_key": "Enter",
    "blocked_move_frame_budget": 10,
    "resume_frame_budget": 2,
    "resumed_move_frame_budget": 10,
    "max_blocked_upward_delta_pixels": 0.1,
    "min_resumed_upward_delta_pixels": 32.0,
    "physics_ticks_per_second": 60,
    "controlled_actor_relative_path": "PlayerActor",
    "initial_position": {
      "x": 640.0,
      "y": 360.0
    }
  },
  "artifact_contract": {
    "required_files": [
      "summary.json",
      "event_log.json",
      "scene_tree.json",
      "console.log",
      "screenshots/before.png",
      "screenshots/paused.png",
      "screenshots/paused_after_move_attempt.png",
      "screenshots/resumed.png",
      "screenshots/after_resume_move.png"
    ],
    "missing_file_is_failure": true
  },
  "exit_codes": {
    "pass": 0,
    "assertion_failure": 1,
    "runtime_error": 2,
    "timeout": 3,
    "artifact_generation_error": 4
  },
  "cli_contract": {
    "command_template": "godot --path <project> -- --test-mode --scenario <path> --artifacts <dir>"
  },
  "steps": [
    {
      "op": "load_harness",
      "scene": "res://examples/minimal_poc/validation/harnesses/modal_pause_movement_harness.tscn"
    },
    {
      "op": "checkpoint",
      "name": "before"
    },
    {
      "op": "press_action",
      "action": "pause"
    },
    {
      "op": "wait_frames",
      "frames": 2
    },
    {
      "op": "release_action",
      "action": "pause"
    },
    {
      "op": "checkpoint",
      "name": "paused"
    },
    {
      "op": "press_action",
      "action": "move_up"
    },
    {
      "op": "wait_frames",
      "frames": 10
    },
    {
      "op": "release_action",
      "action": "move_up"
    },
    {
      "op": "checkpoint",
      "name": "paused_after_move_attempt"
    },
    {
      "op": "assert_value",
      "checkpoint": "paused_after_move_attempt",
      "path": "harness_state.modal_input_block_active",
      "comparator": "eq",
      "expected": true
    },
    {
      "op": "assert_value",
      "checkpoint": "paused_after_move_attempt",
      "path": "harness_state.nodes.actor.physics_processing",
      "comparator": "eq",
      "expected": false
    },
    {
      "op": "assert_pipeline",
      "sources": {
        "paused_y": {
          "kind": "checkpoint",
          "checkpoint": "paused",
          "path": "harness_state.actor_position.y"
        },
        "paused_after_y": {
          "kind": "checkpoint",
          "checkpoint": "paused_after_move_attempt",
          "path": "harness_state.actor_position.y"
        },
        "blocked_threshold": {
          "kind": "contract",
          "path": "done_contract.max_blocked_upward_delta_pixels"
        }
      },
      "pipeline": [
        {
          "op": "subtract",
          "inputs": [
            "paused_y",
            "paused_after_y"
          ],
          "as": "paused_delta_raw"
        },
        {
          "op": "abs",
          "input": "paused_delta_raw",
          "as": "paused_delta_abs"
        }
      ],
      "assert": {
        "actual": "paused_delta_abs",
        "comparator": "lte",
        "expected_source": "blocked_threshold"
      }
    },
    {
      "op": "press_action",
      "action": "ui_accept"
    },
    {
      "op": "wait_frames",
      "frames": 2
    },
    {
      "op": "release_action",
      "action": "ui_accept"
    },
    {
      "op": "checkpoint",
      "name": "resumed"
    },
    {
      "op": "assert_value",
      "checkpoint": "resumed",
      "path": "harness_state.nodes.pause_menu.visible",
      "comparator": "eq",
      "expected": false
    },
    {
      "op": "assert_value",
      "checkpoint": "resumed",
      "path": "harness_state.modal_input_block_active",
      "comparator": "eq",
      "expected": false
    },
    {
      "op": "assert_value",
      "checkpoint": "resumed",
      "path": "harness_state.nodes.actor.physics_processing",
      "comparator": "eq",
      "expected": true
    },
    {
      "op": "press_action",
      "action": "move_up"
    },
    {
      "op": "wait_frames",
      "frames": 10
    },
    {
      "op": "release_action",
      "action": "move_up"
    },
    {
      "op": "checkpoint",
      "name": "after_resume_move"
    },
    {
      "op": "assert_pipeline",
      "sources": {
        "resumed_y": {
          "kind": "checkpoint",
          "checkpoint": "resumed",
          "path": "harness_state.actor_position.y"
        },
        "after_resume_y": {
          "kind": "checkpoint",
          "checkpoint": "after_resume_move",
          "path": "harness_state.actor_position.y"
        },
        "movement_threshold": {
          "kind": "contract",
          "path": "done_contract.min_resumed_upward_delta_pixels"
        }
      },
      "pipeline": [
        {
          "op": "subtract",
          "inputs": [
            "resumed_y",
            "after_resume_y"
          ],
          "as": "upward_delta"
        }
      ],
      "assert": {
        "actual": "upward_delta",
        "comparator": "gte",
        "expected_source": "movement_threshold"
      }
    },
    {
      "op": "quit"
    }
  ]
}
